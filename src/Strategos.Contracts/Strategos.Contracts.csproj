<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>LevelUp.Strategos.Contracts</PackageId>
    <Description>Cross-product schema substrate: TypeSpec-canonical SDLC event, workflow-IR, and invariant contracts emitted as C# records (this DLL) and JSON Schema (NuGet content, consumed by Exarchos).</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IsAotCompatible>true</IsAotCompatible>
    <!-- Generated records carry their own auto-generated banner; suppress
         doc-comment requirements on the emitted partial surface only. -->
    <ContractsSchemasDir>$(MSBuildProjectDirectory)/schemas/json-schema</ContractsSchemasDir>
    <ContractsGeneratedDir>$(MSBuildProjectDirectory)/Generated</ContractsGeneratedDir>
  </PropertyGroup>

  <!-- T32: pin the package version independently of the `v*` product tag.
       MinVer otherwise derives the version from the repo's `v*` release tag
       (which floats at 2.x for the Strategos core line). The contracts
       substrate is an independently versioned cross-product artifact: 0.2.0
       shipped events + workflow IR; 0.3.0 adds the semantic-merge-queue
       surface (MergeGateDecision / JourneyResult / WorkflowRef /
       WorkflowCatalog, the response `_meta.degraded` envelope) and the AGWF
       catalog — all additive (minor bump). MinVer silently overwrites a bare
       <Version>, so per repo convention (cf. Strategos.Agents smoke-pin) we
       also set <MinVerSkip>true</MinVerSkip> + <PackageVersion>. The
       ContractsVersion property keeps the three in lockstep and lets the
       release pipeline bump in one place; the `contracts-v<version>` publish
       workflow fails closed if the tag disagrees with it. -->
  <PropertyGroup>
    <ContractsVersion>0.3.0</ContractsVersion>
    <MinVerSkip>true</MinVerSkip>
    <Version>$(ContractsVersion)</Version>
    <PackageVersion>$(ContractsVersion)</PackageVersion>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="$(AssemblyName).Tests" />
  </ItemGroup>

  <!-- The emitted records under Generated/*.g.cs are picked up by the SDK's
       default Compile glob. They are the consumer-facing contract surface,
       compiled into the DLL, and emitter-owned (see codegen-guard CI); never edit. -->

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="CHANGELOG.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- JSON Schema is embedded as NuGet content so language-neutral consumers
       (Exarchos) receive it with the package (T4). -->
  <ItemGroup>
    <Content Include="schemas/**/*.json" Pack="true" PackagePath="contentFiles/any/any/schemas/" />
  </ItemGroup>

  <!-- #52: the canonical AGWF catalog data artifact (Generated/agwf-catalog.json)
       is embedded as NuGet content alongside the JSON Schema, so Exarchos (#1256)
       extracts it from the package to derive its TypeScript AgwfCode enum. It is
       emitter-owned (codegen-guard) and Pack-only — NOT added to the default
       Compile/Content globs (the Generated/ glob compiles only *.g.cs). -->
  <ItemGroup>
    <Content Include="Generated/agwf-catalog.json"
             Pack="true"
             PackagePath="contentFiles/any/any/diagnostics/"
             CopyToOutputDirectory="Never">
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <!-- T32: embed the #53 builder-fixture corpus under contentFiles/.../fixtures/
       so Exarchos can extract the ≥100 WorkflowDefinitionV1 fixtures from the
       package. The corpus is produced by the fixture-export test
       (artifacts/builder-fixtures/, repo-root, gitignored); it must exist at
       pack time. We do NOT add it to the default Content compile/items globs
       (Pack-only) and reference it by absolute repo path so the working copy is
       unaffected. -->
  <PropertyGroup>
    <ContractsFixturesDir>$(MSBuildProjectDirectory)/../../artifacts/builder-fixtures</ContractsFixturesDir>
  </PropertyGroup>
  <ItemGroup Condition="Exists('$(ContractsFixturesDir)')">
    <Content Include="$(ContractsFixturesDir)/**/*.json"
             Pack="true"
             PackagePath="contentFiles/any/any/fixtures/"
             CopyToOutputDirectory="Never">
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

</Project>
