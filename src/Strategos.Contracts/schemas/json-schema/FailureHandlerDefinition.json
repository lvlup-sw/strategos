{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "FailureHandlerDefinition.json",
    "type": "object",
    "properties": {
        "handlerId": {
            "type": "string",
            "description": "Stable handler identifier."
        },
        "scope": {
            "$ref": "FailureHandlerScope.json",
            "description": "Handler scope (workflow | step | forkPath)."
        },
        "triggerStepId": {
            "type": "string",
            "description": "Step id that triggers this handler, if step-scoped."
        },
        "steps": {
            "type": "array",
            "items": {
                "$ref": "StepDefinition.json"
            },
            "description": "Recovery steps."
        },
        "isTerminal": {
            "type": "boolean",
            "description": "Whether the handler terminates the workflow."
        }
    },
    "required": [
        "handlerId",
        "scope",
        "steps",
        "isTerminal"
    ],
    "description": "Wire-IR failure handler — scoped recovery steps (mirrors the builder's\n`FailureHandlerDefinition`)."
}