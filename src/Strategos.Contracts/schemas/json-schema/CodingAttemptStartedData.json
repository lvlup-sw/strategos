{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "CodingAttemptStartedData.json",
    "type": "object",
    "properties": {
        "taskId": {
            "type": "string"
        },
        "attemptNumber": {
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
        },
        "containerId": {
            "type": "string"
        }
    },
    "required": [
        "taskId",
        "attemptNumber",
        "containerId"
    ],
    "description": "Data payload for `CodingAttemptStarted` events — a container began a TDD attempt."
}