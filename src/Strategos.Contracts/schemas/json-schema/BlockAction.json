{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "BlockAction.json",
    "type": "object",
    "properties": {
        "kind": {
            "type": "string",
            "const": "block",
            "description": "Discriminator: block the merge."
        },
        "reason": {
            "type": "string",
            "minLength": 1,
            "description": "Why the merge is blocked."
        }
    },
    "required": [
        "kind",
        "reason"
    ],
    "description": "`next_actions` branch (#63): block the merge. Carries a human-readable reason\n(not a typed ref — blocking is terminal, there is no journey to run)."
}