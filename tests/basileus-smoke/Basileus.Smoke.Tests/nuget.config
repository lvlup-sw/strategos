<?xml version="1.0" encoding="utf-8"?>
<!--
  Smoke-project-local NuGet config (T-022 / DR-11).

  Adds the sibling local-feed/ directory (populated by
  scripts/pack-to-local-feed.sh) as a package source so that
  `LevelUp.Strategos.Agents 2.7.0-preview.2` resolves from the
  freshly-packed nupkg before nuget.org is consulted.

  Path is relative to this config file's directory:
    .../tests/basileus-smoke/Basileus.Smoke.Tests/  +  ../../../local-feed
    => repo-root/local-feed
-->
<configuration>
  <packageSources>
    <clear />
    <add key="strategos-local" value="../../../local-feed" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
