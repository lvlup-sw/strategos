{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "WorkflowStartedData.json",
    "type": "object",
    "properties": {
        "featureId": {
            "type": "string"
        },
        "workflowType": {
            "$ref": "WorkflowType.json"
        },
        "designPath": {
            "type": "string"
        },
        "synthesisPolicy": {
            "anyOf": [
                {
                    "type": "string",
                    "const": "always"
                },
                {
                    "type": "string",
                    "const": "never"
                },
                {
                    "type": "string",
                    "const": "on-request"
                }
            ]
        }
    },
    "required": [
        "featureId",
        "workflowType"
    ],
    "description": "Data payload for `workflow.started` events."
}